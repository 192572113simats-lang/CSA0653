 import heapq

n,m=map(int,input().split())
g=[[] for _ in range(n)]

for _ in range(m):
    u,v,w=map(int,input().split())
    g[u].append((w,v))
    g[v].append((w,u))

h=[(0,0)]
vis=[0]*n
cost=0

while h:
    w,u=heapq.heappop(h)
    if vis[u]: continue
    vis[u]=1
    cost+=w
    for wt,v in g[u]:
        if not vis[v]:
            heapq.heappush(h,(wt,v))

print(cost)
