def find(x):
if parent[x] != x:
parent[x] = find(parent[x])
return parent[x]

n, m = map(int, input().split())
edges = [tuple(map(int, input().split())) for _ in range(m)]

parent = list(range(n))
cost = 0

for u, v, w in sorted(edges, key=lambda x: x[2]):
    pu, pv = find(u), find(v)
    if pu != pv:
        parent[pu] = pv
        cost += w

print("MST Cost:", cost)
